# Database
# 本地 go run 使用下面这行；Docker 部署由 compose 自动指向 postgres 服务，无需改 host
DATABASE_URL=postgres://surveybox:surveybox@localhost:5432/surveybox?sslmode=disable
# 独立 PostgreSQL（方案 B）时在 docker-compose.override.yml 覆盖 api.environment.DATABASE_URL
POSTGRES_USER=surveybox
POSTGRES_PASSWORD=surveybox
POSTGRES_DB=surveybox
# PostgreSQL 数据目录（宿主机路径，Docker 部署时挂载）
POSTGRES_DATA_DIR=/data/workspace/db/pg/SurveyBox

# Auth（生产环境务必修改 JWT_SECRET）
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# 管理员初始账号（仅首次启动数据库时生效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# File encryption（可选，32 字节 base64；留空则派生自 JWT_SECRET）
FILE_ENCRYPTION_KEY=

# LLM (OpenAI compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=120

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/files

# Branding
ORG_NAME=SurveyBox
ORG_LOGO_URL=
BRAND_PRIMARY=#1677FF

# Server
API_ADDR=:8080
# 对外访问地址（分享链接前缀），Docker 默认 http://localhost
WEB_ORIGIN=http://localhost
WEB_PORT=80
